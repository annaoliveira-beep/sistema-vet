# Arquivo de Configuração de Ambiente
# Copie este arquivo para .env e configure os valores

# Flask
FLASK_APP=app.py
FLASK_ENV=development
DEBUG=True

# Segurança
SECRET_KEY=sua_chave_secreta_muito_segura_aqui_mude_em_producao

# Banco de Dados
DATABASE=clinica_vet.db

# Sessão
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=86400

# Cookie de Segurança (em produção, ative HTTPS primeiro)
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Teste
TESTING=False
